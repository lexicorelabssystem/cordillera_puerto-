{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@cordillera/shared": ["../shared/src/index.ts"],
      "@cordillera/shared/features.js": ["../shared/src/features.ts"]
    }
  },
  "include": ["src"]
}

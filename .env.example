# ============================================================
# CORDILLERA SAAS — Variables de entorno para docker-compose
# Copiar a .env y ajustar para cada ambiente
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=cordillera
POSTGRES_PASSWORD=cambiar_por_password_seguro_min_16_chars
POSTGRES_DB=cordillera_dev
POSTGRES_PORT=5433

# ── Backend ─────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=4000

# JWT: generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=generar_secreto_64_caracteres_con_node_crypto_randomBytes_48

# CORS: dominio(s) del frontend (separados por coma, sin espacios)
#   dev:  http://localhost:5173
#   prod: https://cordillera.ejemplo.cl,https://admin.ejemplo.cl
CORS_ORIGINS=http://localhost:5173

# ── pgAdmin (solo perfil dev) ───────────────────────────
PGADMIN_EMAIL=admin@cordillera.cl
PGADMIN_PASSWORD=AdminDev2026*

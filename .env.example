# Cordillera SaaS environment template.
# Copy to .env locally and replace every change-me placeholder.
# Never commit the resulting .env file.

# Runtime
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# PostgreSQL
POSTGRES_USER=cordillera
POSTGRES_PASSWORD=change-me-generate-secure-random
POSTGRES_DB=cordillera
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication
JWT_SECRET=change-me-generate-secure-random-min-32-characters
JWT_ISSUER=cordillera-saas
JWT_AUDIENCE=cordillera-app
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-me-generate-secure-random-min-32-characters
BCRYPT_ROUNDS=12
ENABLE_DEMO_SEED=false
IMPORTED_STUDENT_TEMP_PASSWORD=change-me-temporary-student-password
IMPORTED_TEACHER_TEMP_PASSWORD=change-me-temporary-teacher-password
LOAD_TEST_PASSWORD=change-me-load-test-password

# URLs and allowed origins
CORS_ORIGINS=https://exact-project.vercel.app
FRONTEND_URL=https://exact-project.vercel.app
VITE_API_BASE_URL=https://api.example.com/api/v1
# Docker host bindings. Keep private services on localhost unless a controlled proxy/VPN is used.
NGINX_BIND_ADDRESS=0.0.0.0
NGINX_PORT=80
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_HOST_PORT=4000
POSTGRES_BIND_ADDRESS=127.0.0.1
REDIS_BIND_ADDRESS=127.0.0.1
REDIS_HOST_PORT=6379
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_HOST_PORT=9090
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_HOST_PORT=3001
PGADMIN_BIND_ADDRESS=127.0.0.1
PGADMIN_HOST_PORT=5050

# Redis and BullMQ
REDIS_URL=redis://user:password@redis-host:6379

# Object storage
STORAGE_DRIVER=minio
MINIO_ENDPOINT=minio-host
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-generate-secure-random
MINIO_DOCUMENTS_BUCKET=educacore-documents
MINIO_TEMP_BUCKET=educacore-temp
MINIO_ARCHIVES_BUCKET=educacore-archives

# SMTP
SMTP_HOST=smtp.provider.example
SMTP_PORT=587
SMTP_USER=change-me-smtp-user
SMTP_PASS=change-me-smtp-password
SMTP_FROM=noreply@educacor.cl
NOTIFICATION_EMAILS_ENABLED=false

# Observability
GRAFANA_ADMIN_USER=change-me-admin-user
GRAFANA_ADMIN_PASSWORD=change-me-generate-secure-random

# Local backup service
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE="0 3 * * *"

# PostgreSQL PITR. Use an external S3-compatible provider, not MinIO on this host.
PITR_S3_BUCKET=change-me-external-backup-bucket
PITR_S3_ENDPOINT=s3.example-provider.com
PITR_S3_REGION=us-east-1
PITR_S3_KEY=change-me-restricted-backup-key
PITR_S3_SECRET=change-me-generate-secure-random
PITR_S3_URI_STYLE=host
PITR_REPO_CIPHER_PASS=change-me-generate-secure-random-min-32-characters
PITR_RETENTION_FULL=4
PITR_RETENTION_DIFF=14
PITR_FULL_BACKUP_DAY=7
PITR_BACKUP_HOUR=2
PITR_ARCHIVE_TIMEOUT=60s
PITR_PROCESS_MAX=2
PITR_CHECK_INTERVAL_SECONDS=300

# Planned variables, not consumed by the application yet:
# CSRF_SECRET=change-me-generate-secure-random
# SMTP_SECURE=false

# ============================================================
# CORDILLERA SAAS — Variables de entorno para docker-compose
# Copiar a .env y ajustar para cada ambiente
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=cordillera
POSTGRES_PASSWORD=cambiar_por_password_seguro_min_16_chars
POSTGRES_DB=cordillera_dev
POSTGRES_PORT=5433

# ── Backend ─────────────────────────────────────────────
NODE_ENV=production
BACKEND_PORT=4000

# JWT: generar con: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=generar_secreto_64_caracteres_con_node_crypto_randomBytes_48

# CORS: dominio(s) del frontend (separados por coma, sin espacios)
#   dev:  http://localhost:5173
#   prod exacto: https://cordillera.ejemplo.cl,https://admin.ejemplo.cl
#   prod Vercel: *.vercel.app
CORS_ORIGINS=http://localhost:5173

# Frontend Vite (Vercel)
VITE_API_BASE_URL=https://cordillera-backend.onrender.com/api/v1

# ── pgAdmin (solo perfil dev) ───────────────────────────
PGADMIN_EMAIL=admin@cordillera.cl
PGADMIN_PASSWORD=AdminDev2026*

# ── SMTP / Notificaciones Email (opcional) ──────────────
# Dejar SMTP_HOST vacío para desactivar envío de emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cordillera.cl
NOTIFICATION_EMAILS_ENABLED=false
FRONTEND_URL=http://localhost

# ── Redis (opcional) ────────────────────────────────────
# Dejar vacío para usar caché en memoria
REDIS_URL=

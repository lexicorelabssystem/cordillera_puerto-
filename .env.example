# Cordillera SaaS environment template.
# Copy to .env locally and replace every change-me placeholder.
# Never commit the resulting .env file.

# Runtime
NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# PostgreSQL
POSTGRES_USER=cordillera
POSTGRES_PASSWORD=change-me-generate-secure-random
POSTGRES_DB=cordillera
POSTGRES_PORT=5433
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication
JWT_SECRET=change-me-generate-secure-random-min-32-characters
JWT_ISSUER=cordillera-saas
JWT_AUDIENCE=cordillera-app
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-me-generate-secure-random-min-32-characters
BCRYPT_ROUNDS=12
ENABLE_DEMO_SEED=false

# URLs and allowed origins
CORS_ORIGINS=https://exact-project.vercel.app
FRONTEND_URL=https://exact-project.vercel.app
VITE_API_BASE_URL=https://api.example.com/api/v1

# Redis and BullMQ
REDIS_URL=redis://user:password@redis-host:6379

# Object storage
STORAGE_DRIVER=minio
MINIO_ENDPOINT=minio-host
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-generate-secure-random
MINIO_DOCUMENTS_BUCKET=educacore-documents
MINIO_TEMP_BUCKET=educacore-temp
MINIO_ARCHIVES_BUCKET=educacore-archives

# SMTP
SMTP_HOST=smtp.provider.example
SMTP_PORT=587
SMTP_USER=change-me-smtp-user
SMTP_PASS=change-me-smtp-password
SMTP_FROM=noreply@educacor.cl
NOTIFICATION_EMAILS_ENABLED=false

# Observability
GRAFANA_ADMIN_USER=change-me-admin-user
GRAFANA_ADMIN_PASSWORD=change-me-generate-secure-random

# Local backup service
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 3 * * *

# Planned variables, not consumed by the application yet:
# CSRF_SECRET=change-me-generate-secure-random
# SMTP_SECURE=false
# BACKUP_TARGET=s3://external-backup-bucket

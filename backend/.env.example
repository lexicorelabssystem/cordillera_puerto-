NODE_ENV=development
PORT=4000
HOST=0.0.0.0

DATABASE_URL=postgresql://cordillera:cordillera_dev_2026@localhost:5432/cordillera_dev

JWT_SECRET=<generar con: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))">
JWT_ISSUER=cordillera-saas
JWT_AUDIENCE=cordillera-app
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

ENABLE_DEMO_SEED=true
BCRYPT_ROUNDS=10

# SMTP (opcional — dejar vacío para desactivar envío de emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@cordillera.cl
NOTIFICATION_EMAILS_ENABLED=false

# Redis (opcional — dejar vacío para usar caché en memoria)
REDIS_URL=

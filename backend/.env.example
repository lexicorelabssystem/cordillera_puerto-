# Backend-only development template.
# Copy to backend/.env and replace all change-me placeholders.

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

DATABASE_URL=postgresql://user:password@localhost:5432/database

JWT_SECRET=change-me-generate-secure-random-min-32-characters
JWT_ISSUER=cordillera-saas
JWT_AUDIENCE=cordillera-app
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change-me-generate-secure-random-min-32-characters

CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

ENABLE_DEMO_SEED=false
BCRYPT_ROUNDS=12

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@educacor.cl
NOTIFICATION_EMAILS_ENABLED=false

REDIS_URL=redis://localhost:6379

STORAGE_DRIVER=local
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-generate-secure-random
MINIO_DOCUMENTS_BUCKET=educacore-documents
MINIO_TEMP_BUCKET=educacore-temp
MINIO_ARCHIVES_BUCKET=educacore-archives
